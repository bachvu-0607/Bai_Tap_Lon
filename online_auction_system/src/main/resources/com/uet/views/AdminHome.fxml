<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane prefHeight="975.2" prefWidth="908.0" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <top>
      <HBox prefHeight="46.0" prefWidth="908.0" BorderPane.alignment="CENTER">
         <children>
            <Label prefHeight="46.0" prefWidth="260.0" text="⚙ ADMIN HOME">
               <font>
                  <Font size="29.0" />
               </font>
            </Label>
            <Region prefHeight="46.0" prefWidth="320.0" />
            <Label fx:id="adminHome" prefHeight="46.0" prefWidth="160.0" />
            <Button mnemonicParsing="false" prefHeight="44.0" prefWidth="114.0" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" text="← Auction List " />
         </children>
      </HBox>
   </top>
   <center>
      <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
        <tabs>
            <Tab text="👥 Quản lý người dùng">
               <content>
                  <VBox spacing="10" style="-fx-padding: 15;">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Danh sách người dùng" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button onAction="#loadUsers" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" text="Làm mới" />
                           </children>
                        </HBox>
                        <TableView fx:id="usersTable" style="-fx-background-color: #16213e;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colUsername" prefWidth="150" text="Tên đăng nhập" />
                              <TableColumn fx:id="colFullName" prefWidth="180" text="Họ tên" />
                              <TableColumn fx:id="colEmail" prefWidth="200" text="Email" />
                              <TableColumn fx:id="colRole" prefWidth="100" text="Vai trò" />
                              <TableColumn fx:id="colActive" prefWidth="224.80001220703127" text="Trạng thái" />
                           </columns>
                        </TableView>
                        <HBox spacing="10">
                           <children>
                              <Button onAction="#handleDeactivateUser" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" text="Vô hiệu hóa tài khoản" />
                              <Label fx:id="userActionLabel" style="-fx-text-fill: #4caf50;" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </Tab>
            <Tab text="🏆 Quản lý đấu giá">
               <content>
                  <VBox spacing="10" style="-fx-padding: 15;">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                           <children>
                              <Label style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Tất cả phiên đấu giá" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Button onAction="#loadAuctions" style="-fx-background-color: #0f3460; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" text="Làm mới" />
                           </children>
                        </HBox>
                        <TableView fx:id="auctionsTable" style="-fx-background-color: #16213e;" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colAuctionItem" prefWidth="200" text="Sản phẩm" />
                              <TableColumn fx:id="colAuctionSeller" prefWidth="120" text="Seller ID" />
                              <TableColumn fx:id="colAuctionPrice" prefWidth="120" text="Giá hiện tại" />
                              <TableColumn fx:id="colAuctionStatus" prefWidth="100" text="Trạng thái" />
                              <TableColumn fx:id="colAuctionBids" prefWidth="80" text="Số bid" />
                              <TableColumn fx:id="colAuctionEnd" prefWidth="235.199951171875" text="Kết thúc" />
                           </columns>
                        </TableView>
                        <HBox spacing="10">
                           <children>
                              <Button onAction="#handleCancelAuction" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 6 14;" text="Hủy phiên đấu giá" />
                              <Label fx:id="auctionActionLabel" style="-fx-text-fill: #4caf50;" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </Tab>
        </tabs>
      </TabPane>
   </center>
   <bottom>
      <HBox BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="statusBarAdmin" prefHeight="18.0" prefWidth="76.0" style="-fx-text-fill: #4caf50; -fx-font-size: 11;" text="Admin panel" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
